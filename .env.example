# =====================================================================
#  Configuration du bot - copie ce fichier en ".env" et remplis-le
# =====================================================================

# Token de ton bot (Discord Developer Portal > ton application > Bot > Reset Token)
DISCORD_TOKEN=colle_ton_token_ici

# (Optionnel) ID de ton serveur de test.
# Si rempli, les commandes slash apparaissent INSTANTANEMENT sur ce serveur.
# Si vide, synchro globale (peut prendre jusqu'a 1h la 1ere fois).
DEV_GUILD_ID=

# (Optionnel) Base de donnees. Par defaut : SQLite local dans data/config.db
# Pour un hebergement separe plus tard, on pourra mettre une URL Postgres ici.
# DATABASE_URL=sqlite:///data/config.db
